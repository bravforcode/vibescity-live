{
	"version": 8,
	"name": "VibeCity Dev Safe 2D",
	"id": "vibecity-dev",
	"glyphs": "https://fonts.openmaptiles.org/{fontstack}/{range}.pbf",
	"sources": {
		"openmaptiles": {
			"type": "vector",
			"url": "https://tiles.openfreemap.org/planet/tiles.json"
		}
	},
	"layers": [
		{
			"id": "background",
			"type": "background",
			"paint": {
				"background-color": "#08101b"
			}
		},
		{
			"id": "water",
			"type": "fill",
			"source": "openmaptiles",
			"source-layer": "water",
			"paint": {
				"fill-color": "#102544"
			}
		},
		{
			"id": "roads-minor",
			"type": "line",
			"source": "openmaptiles",
			"source-layer": "transportation",
			"filter": [
				"all",
				["==", ["geometry-type"], "LineString"],
				[
					"in",
					["get", "class"],
					["literal", ["minor", "minor_road", "service", "track", "path"]]
				]
			],
			"layout": {
				"line-join": "round",
				"line-cap": "round"
			},
			"paint": {
				"line-color": "#22344e",
				"line-width": [
					"interpolate",
					["linear"],
					["zoom"],
					8,
					0.35,
					14,
					1.1,
					18,
					1.9
				],
				"line-opacity": 0.72
			}
		},
		{
			"id": "roads-major-glow",
			"type": "line",
			"source": "openmaptiles",
			"source-layer": "transportation",
			"filter": [
				"all",
				["==", ["geometry-type"], "LineString"],
				[
					"in",
					["get", "class"],
					["literal", ["primary", "secondary", "tertiary", "trunk", "motorway"]]
				]
			],
			"layout": {
				"line-join": "round",
				"line-cap": "round"
			},
			"paint": {
				"line-color": "#49b7ff",
				"line-width": [
					"interpolate",
					["linear"],
					["zoom"],
					8,
					2.2,
					14,
					5.4,
					18,
					8.8
				],
				"line-blur": ["interpolate", ["linear"], ["zoom"], 8, 0.45, 16, 1.6],
				"line-opacity": 0.28
			}
		},
		{
			"id": "roads-major",
			"type": "line",
			"source": "openmaptiles",
			"source-layer": "transportation",
			"filter": [
				"all",
				["==", ["geometry-type"], "LineString"],
				[
					"in",
					["get", "class"],
					["literal", ["primary", "secondary", "tertiary", "trunk", "motorway"]]
				]
			],
			"layout": {
				"line-join": "round",
				"line-cap": "round"
			},
			"paint": {
				"line-color": "#7ad0ff",
				"line-width": [
					"interpolate",
					["linear"],
					["zoom"],
					8,
					0.8,
					14,
					2.2,
					18,
					3.8
				],
				"line-opacity": 0.92
			}
		}
	]
}
