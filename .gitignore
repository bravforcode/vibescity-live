# ----------------------------------------
# 7. Project Specific (Large Assets)
# ----------------------------------------
# Prevent large GeoJSON files from being uploaded to Git
public/data/chiangmai-main-roads-lanes.geojson
public/data/chiangmai-main-roads.geojson

# Prevent accidental large extension bundles/assets from landing in public/
*.vsix
public/images/animation/*.vsix

