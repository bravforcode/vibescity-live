# ----------------------------------------
# 4. Environment Variables (CRITICAL SECURITY)
# ----------------------------------------
# Block all .env files to prevent token leaks
.env
.env.local
.env.*
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# Allow example env files
!.env.example

# Sentry Config Auth Token
.env.sentry-build-plugin

# Local MCP config files
.mcp.json
mcp_config_ready_to_copy.json
mcp_config*.local.json

# Local agent/editor tool folders
.cursor/
.windsurf/

