{
  "name": "vibescity-live",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "rsbuild dev --port 5173",
    "build": "rsbuild build && node scripts/prerender-venues.mjs",
    "preview": "rsbuild preview",
    "check": "biome check --write src && node scripts/ci/check-source-i18n-hardcoded.mjs",
    "check:bundle": "node scripts/check-bundle-sizes.mjs",
    "format": "biome format --write src",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "build:roads:cm": "node scripts/build-chiangmai-roads.mjs",
    "build:roads:cm:lanes": "node scripts/road-lanes.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "cross-env PW_LOW_MEM=1 PW_CONSOLE_ALLOW_BLOCKED=1 PW_GREP=@smoke PW_GREP_INVERT=@smoke-map-lite playwright test --project=\"Desktop Chromium\"",
    "test:e2e:smoke-map-lite": "cross-env PW_LOW_MEM=1 PW_GREP=@smoke-map-lite PW_NO_WEBSERVER=1 E2E_MAP_REQUIRED=1 playwright test --project=\"Desktop Chromium\"",
    "test:e2e:map-preflight": "cross-env PW_LOW_MEM=1 PW_GREP=@map-preflight E2E_MAP_REQUIRED=1 playwright test --project=\"Desktop Chromium\"",
    "test:e2e:map-required": "cross-env PW_LOW_MEM=1 PW_GREP=@map-required PW_GREP_INVERT=@map-quarantine E2E_MAP_REQUIRED=1 playwright test --project=\"Desktop Chromium\"",
    "test:e2e:map-quarantine": "cross-env PW_LOW_MEM=1 PW_GREP=@map-quarantine playwright test --project=\"Desktop Chromium\"",
    "test:e2e:debug": "PW_SLOWMO=150 playwright test --debug",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "healthcheck": "node scripts/healthcheck-manual-order.mjs",
    "healthcheck:postdeploy": "node scripts/healthcheck-post-deploy.mjs",
    "test:load": "node scripts/k6/report.mjs --prepare && k6 run k6-tests/realistic-load.js && node scripts/k6/report.mjs --build",
    "test:spike": "k6 run k6-tests/spike-test.js",
    "test:chaos": "k6 run k6-tests/chaos-test.js",
    "ci:weekly-trend": "node scripts/ci/weekly-quality-trend.mjs",
    "ci:monthly-trend": "cross-env TREND_DAYS=30 TREND_TITLE=\"Monthly Quality Trend Summary\" TREND_OUTPUT_PATH=reports/ci/monthly-quality-trend.json node scripts/ci/weekly-quality-trend.mjs",
    "ci:route-slo": "node scripts/ci/evaluate-route-slo.mjs",
    "ci:seo-lint": "node scripts/ci/seo-lint.mjs",
    "ci:db-migration-safety": "node scripts/ci/validate-migrations-safety.mjs",
    "ci:sw-contract": "node scripts/ci/check-sw-contract.mjs",
    "ci:perf-budget": "node scripts/ci/check-perf-budget.mjs --budget perf-budget.json",
    "ci:bundle-budget": "node scripts/check-bundle-sizes.mjs",
    "ci:source-console-budget": "node scripts/ci/check-source-console-budget.mjs",
    "ci:source-i18n": "node scripts/ci/check-source-i18n-hardcoded.mjs",
    "ci:vite-public-secrets": "node scripts/ci/check-vite-public-secrets.mjs",
    "ci:prod-ready": "node scripts/ci/prod-ready-gate.mjs",
    "ci:cache-warm-seo": "node scripts/ci/cache-warm-seo.mjs",
    "ci:secret-scan:gitleaks": "node scripts/ci/secret-scan-gitleaks.mjs",
    "ci:provision-bq-analytics": "node scripts/ci/provision-bigquery-analytics.mjs",
    "ci:export-analytics-warehouse": "node scripts/ci/export-analytics-archive-daily-to-bigquery.mjs",
    "ci:publish-metrics": "node scripts/ci/publish-observability-metrics.mjs",
    "ci:manage-incidents": "node scripts/ci/manage-incidents.mjs",
    "ci:secret-scan": "node scripts/ci/secret-scan.mjs",
    "media:upload:venues": "node scripts/auto-upload-venue-media.mjs",
    "media:upload:venues:auto": "node scripts/run-media-autofill-auto.mjs",
    "media:autofill:task:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-media-autofill-task.ps1",
    "media:autofill:task:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-media-autofill-task.ps1",
    "hooks:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-hooks.ps1",
    "knip": "knip -c knip.json --no-progress",
    "knip:deps": "knip -c knip.json --include dependencies,unlisted,binaries,unresolved --no-progress",
    "knip:files": "knip -c knip.json --include files --no-progress",
    "knip:exports": "knip -c knip.json --include exports,types,duplicates --no-progress",
    "i18n:check": "node scripts/ci/check-source-i18n-hardcoded.mjs",
    "i18n:fix": "node scripts/ci/codemod-i18n-hardcoded.mjs && node scripts/ci/repair-i18n-codemod.mjs",
    "i18n:sync": "node scripts/ci/i18n-sync-checker.mjs",
    "i18n:translate": "node scripts/ci/i18n-auto-translate.mjs",
    "i18n:orphans": "node scripts/ci/i18n-orphan-checker.mjs",
    "i18n:tracker": "node scripts/ci/i18n-translation-tracker.mjs",
    "i18n:autopilot": "node scripts/ci/i18n-autopilot.mjs",
    "perf:baseline": "lighthouse http://localhost:5173 --throttling-method=simulate --cpu-slowdown-multiplier=4 --output=json --output-path=baseline-lh.json",
    "perf:fps:mobile": "node scripts/performance/run-mobile-fps-benchmark.mjs --output reports/performance/map-fps-benchmark.json",
    "perf:fps:ios:ingest": "node scripts/performance/ingest-ios-instruments-export.mjs",
    "perf:fps:real-device": "node scripts/performance/run-real-device-mobile-benchmark.mjs --output reports/performance/map-fps-real-device.json",
    "ci:map-fps-guardrail": "node scripts/ci/check-map-fps-guardrail.mjs --input reports/performance/map-fps-benchmark.json",
    "perf:all": "node scripts/performance/run-perf-all.mjs",
    "ci:branch-protect:map-fps": "node scripts/ci/set-map-fps-required-check.mjs --branch main --context map-fps-guardrail",
    "ci:branch-protect:dashboard-canary": "node scripts/ci/set-dashboard-canary-required-checks.mjs --branch main",
    "perf:compare": "node scripts/compare-perf.mjs",
    "perf:monitor": "node scripts/monitor-perf-db.mjs",
    "prepare": "husky",
    "dev:backend": "cd backend && python run_backend.py",
    "types:api": "openapi-typescript http://127.0.0.1:8000/openapi.json -o src/types/api.types.ts",
    "types:db": "supabase gen types typescript --local > src/types/database.types.ts",
    "dev:all": "run-p dev dev:backend types:sync",
    "types:sync": "node scripts/dev-types-watcher.mjs",
    "venue:validate": "node scripts/ci/validate-venue-data.mjs",
    "components:audit": "node scripts/ci/audit-components.mjs",
    "flags:audit": "node scripts/ci/audit-feature-flags.mjs",
    "api:validate": "node scripts/ci/validate-api-contract-enhanced.mjs",
    "test:device-matrix": "node scripts/ci/generate-device-matrix.mjs",
    "i18n:validate-thai": "node scripts/ci/validate-thai-locale.mjs",
    "monitor:flag-sunsets": "node scripts/ci/monitor-flag-sunsets.mjs",
    "audit:cleanup": "cat scripts/cleanup-unused-components.md"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify/vue": "^5.0.0",
    "@mapbox/mapbox-gl-geocoder": "^5.1.2",
    "@microsoft/clarity": "^1.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-web": "^0.41.0",
    "@opentelemetry/context-zone": "^2.6.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@opentelemetry/instrumentation": "^0.53.0",
    "@opentelemetry/resources": "^1.26.0",
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "@opentelemetry/sdk-trace-web": "^1.26.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@sentry/vite-plugin": "^4.7.0",
    "@sentry/vue": "^10.36.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/vue-query": "^5.92.8",
    "@turf/helpers": "^7.3.2",
    "@turf/line-offset": "^7.3.2",
    "@vercel/speed-insights": "^1.3.1",
    "@vueuse/core": "^14.2.0",
    "@vueuse/motion": "^3.0.3",
    "aos": "^2.3.4",
    "axios": "^1.13.2",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "csv-parser": "^3.2.0",
    "dayjs": "^1.11.19",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "idb-keyval": "^6.2.2",
    "lottie-web": "^5.13.0",
    "lucide-vue-next": "^0.562.0",
    "maplibre-gl": "^4.7.0",
    "papaparse": "^5.5.3",
    "pinia": "^3.0.4",
    "promptpay-qr": "^0.5.0",
    "qrcode.vue": "^3.8.0",
    "uuid": "^13.0.0",
    "vue": "^3.5.24",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vue-virtual-scroller": "2.0.0-beta.8",
    "vue3-lottie": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@biomejs/biome": "^2.3.11",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.0",
    "@rsbuild/core": "^1.7.2",
    "@rsbuild/plugin-vue": "^1.2.3",
    "@storybook/addon-a11y": "^10.2.0",
    "@storybook/addon-docs": "^10.2.0",
    "@storybook/addon-onboarding": "^10.2.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/node": "^25.0.10",
    "@unhead/vue": "^2.1.2",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/compiler-sfc": "^3.5.27",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "fast-check": "^4.6.0",
    "happy-dom": "^20.3.7",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "knip": "^5.83.0",
    "lighthouse": "^12.8.2",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^7.13.0",
    "pinia-plugin-persistedstate": "^4.7.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.5",
    "storybook": "^10.2.0",
    "storybook-vue3-rsbuild": "^3.2.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0",
    "xml2js": "^0.6.2"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,vue}": [
      "biome check --no-errors-on-unmatched --write",
      "biome format --no-errors-on-unmatched --write"
    ]
  }
}
